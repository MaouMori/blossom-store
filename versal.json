{
  "version": 2,
  "functions": {
    "api/*.js": {
      "runtime": "@vercel/node@3.0.0"
    }
  },
  "routes": [
    { "src": "/api/store", "dest": "/api/store.js" },
    { "src": "/api/orders", "dest": "/api/orders.js" },
    { "src": "/api/auth", "dest": "/api/auth.js" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}